{
  "name": "weight-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://shankarpandala.github.io/weight-management",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audio:voiceover": "node scripts/generate-voiceover.mjs",
    "cellbio:audio": "node scripts/generate-c1-cell-biology-voiceovers.mjs",
    "cellbio4k:audio": "node scripts/generate-c1-cell-biology-lecture-voiceovers.mjs",
    "remotion:preview": "remotion preview src/remotion/index.jsx",
    "remotion:render": "remotion render src/remotion/index.jsx PandalaPromoShort out/pandala-promo-shorts.mp4",
    "promo:render": "npm run audio:voiceover && npm run remotion:render",
    "cellbio:render:en": "remotion render src/remotion/index.jsx CellBiologyLectureEN out/c1-cell-biology-lecture-en.mp4",
    "cellbio:render:te": "remotion render src/remotion/index.jsx CellBiologyLectureTE out/c1-cell-biology-lecture-te.mp4",
    "cellbio:render": "npm run cellbio:audio && npm run cellbio:render:en && npm run cellbio:render:te",
    "cellbio4k:render:en": "remotion render src/remotion/index.jsx CellBiologyLecture4KEN out/c1-cell-biology-lecture-4k-en.mp4 --concurrency=4",
    "cellbio4k:render:te": "remotion render src/remotion/index.jsx CellBiologyLecture4KTE out/c1-cell-biology-lecture-4k-te.mp4 --concurrency=4",
    "cellbio4k:render": "npm run cellbio4k:audio && npm run cellbio4k:render:en && npm run cellbio4k:render:te",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.39.0",
    "@remotion/cli": "^4.0.438",
    "d3": "^7.9.0",
    "framer-motion": "^12.35.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "remotion": "^4.0.438",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "gh-pages": "^6.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
